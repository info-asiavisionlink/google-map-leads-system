GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# 共通ダッシュボード側 Supabase（ユーザー情報・クレジット残高の正本）
# Service Role Key はサーバー側 API のみで使用すること（NEXT_PUBLIC_ を付けない）
DASHBOARD_SUPABASE_URL=
DASHBOARD_SUPABASE_SERVICE_ROLE_KEY=

NEXT_PUBLIC_DASHBOARD_BASE_URL=
# 管理システム API（未設定時は NEXT_PUBLIC_DASHBOARD_BASE_URL を使用）
AUTH_SYSTEM_API_URL=
# 後方互換: DASHBOARD_SUPABASE_* 未設定時に使用
AUTH_SUPABASE_URL=
AUTH_SUPABASE_ANON_KEY=
AUTH_SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_TOOL_KEY=

# Google Cloud で有効化: Places API (New), Geocoding API

# 認証デバッグ（原因特定後に false / 削除）
NEXT_PUBLIC_AUTH_DEBUG=false
AUTH_DEBUG=false
